# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AAF...
# Your personal chat ID (send /start to @userinfobot to find it)
TELEGRAM_CHAT_ID=123456789

# ── Apify ─────────────────────────────────────────────────────────────────────
APIFY_API_KEY=apify_api_...

# ── LeBonCoin credentials ─────────────────────────────────────────────────────
LBC_EMAIL=your@email.com
LBC_PASSWORD=your_password

# ── Optional overrides ────────────────────────────────────────────────────────
# DB_PATH=data/bot.db
# LOG_FILE=leboncoin_bot.log
# MAX_MESSAGES_PER_HOUR=20
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Mock mode — set to true to skip all paid APIs (Anthropic + Apify + LBC) ──
# MOCK_MODE=true

# ── Scraper engine ────────────────────────────────────────────────────────────
# Default: Playwright (free, runs locally, opens a browser window briefly)
# Set USE_APIFY=true only if Playwright gets blocked by DataDome
# USE_APIFY=true

# ── Additional sources (optional — override if default URLs don't match your criteria) ──
# Set the var to an empty string to disable a source.
# Generalist portals:
# BIENICI_SEARCH_URL=https://www.bienici.com/recherche/location/paris-ile-de-france?prix-max=1000&surface-min=25&meuble=true
# LOGICIMMO_SEARCH_URL=https://www.logic-immo.com/location-appartement/paris,ile-de-france?avec=meuble&surface-min=25&prix-max=1000
# Student / young-pro / medium-term platforms:
# STUDAPART_SEARCH_URL=https://www.studapart.com/fr/search?city=paris&priceMax=1000&surfaceMin=25
# PARISATTITUDE_SEARCH_URL=https://www.parisattitude.com/recherche?priceMax=1000
# LODGIS_SEARCH_URL=https://www.lodgis.com/locations-paris?prixMax=1000&surfaceMin=25
# IMMOJEUNE_SEARCH_URL=https://www.immojeune.com/locations?ville=paris&loyer-max=1000&surface-min=25
# LOCSERVICE_SEARCH_URL=https://www.locservice.fr/recherche.html?ville=paris&loyer-max=1000
# ROOMLALA_SEARCH_URL=https://www.roomlala.com/fr/recherche?city=paris&priceMax=1000

# ── Fast poller (/watch command) ─────────────────────────────────────────────
# FAST_POLL_INTERVAL_MIN=15

# ── Dossier pre-screening (costs ~$0.003/listing, off by default) ─────────────
# ENABLE_PRESCREENING=true

# ── Listing scoring (costs ~$0.005/listing, off by default) ──────────────────
# When ENABLE_SCORING=true, every contacted listing is scored 1-10 by Claude.
# Listings >= INTEREST_THRESHOLD trigger a 🔥 priority alert in Telegram.
# ENABLE_SCORING=true
# MIN_SCORE=6
# INTEREST_THRESHOLD=8

# ── Photo analysis (costs ~$0.012/listing, off by default) ───────────────────
# ENABLE_PHOTO_ANALYSIS=true

# ── Stale contact threshold (days without reply before shown in /rapport) ────
# STALE_DAYS=5

# ── Google Sheets sync (optional — auto-disabled if either var is missing) ───
# Setup: see SHEETS_SETUP.md
# GOOGLE_SHEET_ID=1AbCDeFgHiJkLmNoPqRsTuVwXyZ-aBcDeFgHiJkLmNo
# GOOGLE_SERVICE_ACCOUNT_JSON=data/google_service_account.json
# Auto-sync at end of /campagne (default true):
# SYNC_AFTER_CAMPAIGN=true
