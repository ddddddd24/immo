# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AAF...
# Your personal chat ID (send /start to @userinfobot to find it)
TELEGRAM_CHAT_ID=123456789

# ── Apify ─────────────────────────────────────────────────────────────────────
APIFY_API_KEY=apify_api_...

# ── LeBonCoin credentials ─────────────────────────────────────────────────────
LBC_EMAIL=your@email.com
LBC_PASSWORD=your_password

# ── Optional overrides ────────────────────────────────────────────────────────
# DB_PATH=data/bot.db
# LOG_FILE=leboncoin_bot.log
# MAX_MESSAGES_PER_HOUR=20
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Mock mode — set to true to skip all paid APIs (Anthropic + Apify + LBC) ──
# MOCK_MODE=true

# ── Scraper engine ────────────────────────────────────────────────────────────
# Default: Playwright (free, runs locally, opens a browser window briefly)
# Set USE_APIFY=true only if Playwright gets blocked by DataDome
# USE_APIFY=true

# ── Additional sources (optional — override if default URLs don't match your criteria) ──
# BIENICI_SEARCH_URL=https://www.bienici.com/recherche/location/paris-ile-de-france?prix-max=1000&surface-min=25&meuble=true
# LOGICIMMO_SEARCH_URL=https://www.logic-immo.com/location-appartement/paris,ile-de-france?avec=meuble&surface-min=25&prix-max=1000

# ── Fast poller (/watch command) ─────────────────────────────────────────────
# FAST_POLL_INTERVAL_MIN=15

# ── Dossier pre-screening (costs ~$0.003/listing, off by default) ─────────────
# ENABLE_PRESCREENING=true

# ── Stale contact threshold (days without reply before shown in /rapport) ────
# STALE_DAYS=5
